{
  "private": true,
  "name": "electron-app",
  "version": "0.0.0",
  "main": "lib/backend/electron-main.js",
  "dependencies": {
    "@theia/core": "1.71.0",
    "@theia/editor": "1.71.0",
    "@theia/electron": "1.71.0",
    "@theia/filesystem": "1.71.0",
    "@theia/markers": "1.71.0",
    "@theia/messages": "1.71.0",
    "@theia/monaco": "1.71.0",
    "@theia/navigator": "1.71.0",
    "@theia/preferences": "1.71.0",
    "@theia/process": "1.71.0",
    "@theia/terminal": "1.71.0",
    "@theia/workspace": "1.71.0",
    "@theia/vscode-builtin-python": "1.71.0",
    "@theia/vscode-builtin-javascript": "1.71.0",
    "@theia/vscode-builtin-typescript": "1.71.0",
    "@theia/vscode-builtin-json": "1.71.0",
    "@theia/vscode-builtin-css": "1.71.0",
    "@theia/vscode-builtin-html": "1.71.0",
    "@theia/vscode-builtin-markdown": "1.71.0",
    "@theia/vscode-builtin-yaml": "1.71.0",
    "rta-desktop": "0.0.0"
  },
  "devDependencies": {
    "@theia/cli": "1.71.0",
    "electron": "39.8.7"
  },
  "scripts": {
    "bundle": "npm run rebuild && theia build --mode development",
    "rebuild": "theia rebuild:electron --cacheRoot ..",
    "start": "theia start",
    "watch": "npm run rebuild && theia build --watch --mode development"
  },
  "theia": {
    "target": "electron",
    "frontendOptions": {
      "applicationName": "Rta"
    },
    "electron": {
      "icon": "node_modules/rta-desktop/src/browser/style/rta-icon.png"
    }
  }
}
